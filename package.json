{
  "name": "@gshanmukha/lodestar",
  "version": "0.1.1",
  "description": "Know what your AI actually did. A tamper-evident execution history for AI coding agent sessions.",
  "type": "module",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Gshanmuk8/Loadstar.git"
  },
  "homepage": "https://github.com/Gshanmuk8/Loadstar#readme",
  "bugs": {
    "url": "https://github.com/Gshanmuk8/Loadstar/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=22.13"
  },
  "bin": {
    "lodestar": "dist/cli/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "verifier"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepublishOnly": "npm run build",
    "dev": "tsx src/cli/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json",
    "stress": "npm run build && node --disable-warning=ExperimentalWarning stress/run-all.mjs",
    "vectors": "tsx spec/generate-vectors.ts",
    "check": "npm run typecheck && npm run test && npm run stress"
  },
  "dependencies": {
    "chokidar": "^4.0.1",
    "picomatch": "^4.0.5",
    "simple-git": "^3.27.0"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@types/picomatch": "^4.0.3",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^4.1.10"
  },
  "keywords": [
    "ai",
    "agents",
    "audit",
    "observability",
    "trust"
  ]
}
