      "formatVersion": 1,
      "author": "alice",
      "ts": "2026-07-20T00:00:00.000Z",
      "type": "identity:same-repo",
      "from": "evidence:repo/github.com/acme/infra",
      "to": "evidence:repo/github.com/acme/platform",
      "reason": "acme/infra was renamed to acme/platform"
    },
    "expectedLinkId": "fd3294702b0a0d622d35d2aff5bdc27efe3d7646098a73c6d8e1ca2bfc29f47b"
  },
